  BackgroundColor #FDEBD0
  BorderColor #A04000
}
skinparam packageStyle rectangle
left to right direction

actor "Administrator" as Admin
actor "Analityk /\nWłaściciel raportu" as Analyst
actor "Przeglądający\n(Viewer)" as Viewer
actor "System\n(Scheduler)" as Scheduler
actor "AI Analysis\nEngine" as AI

rectangle "ARGUS — Automated Reporting Governance & Unified Surveillance Platform" {

  package "Katalog i nawigacja" {
    usecase "UC-01\nPrzegląd katalogu raportów\nwg obszarów biznesowych" as UC01
    usecase "UC-02\nWyszukiwanie raportu" as UC02
  }

  package "Konfiguracja testów" {
    usecase "UC-03\nDefiniowanie Validation Profile\ndla raportu" as UC03
    usecase "UC-04\nDefiniowanie testu SQL" as UC04
    usecase "UC-05\nDefiniowanie testu\nwartości pola (KPI)" as UC05
    usecase "UC-06\nDefiniowanie reguły\nbiznesowej" as UC06
    usecase "UC-07\nUstawienie harmonogramu\nwykonania testów" as UC07
  }

  package "Wykonanie testów" {
    usecase "UC-08\nRęczne uruchomienie\ntestu / grupy testów" as UC08
    usecase "UC-09\nAutomatyczne wykonanie\ntestów wg harmonogramu" as UC09
  }

  package "Wyniki i metryki" {
    usecase "UC-10\nPrzegląd wyniku\nprzebiegu testowego" as UC10
    usecase "UC-11\nPrzegląd historii\nwyników raportu" as UC11
    usecase "UC-12\nPrzegląd Health Score" as UC12
    usecase "UC-13\nPrzegląd Confidence Score" as UC13
    usecase "UC-14\nFiltrowanie i przegląd\nbłędów" as UC14
  }

  package "AI" {
    usecase "UC-15\nPrzegląd analizy\ni wyjaśnienia AI" as UC15
  }

  package "Powiadomienia" {
    usecase "UC-16\nOtrzymanie powiadomienia\no wykrytym problemie" as UC16
  }

  package "Administracja" {
    usecase "UC-17\nZarządzanie użytkownikami\ni rolami (RBAC)" as UC17
    usecase "UC-18\nZarządzanie katalogiem\nplatform / connectorów" as UC18
    usecase "UC-19\nPrzegląd logu\naudytowego" as UC19
    usecase "UC-20\nPrzegląd metryk\noperacyjnych" as UC20
  }
}

